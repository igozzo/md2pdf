{
  "name": "md2pdf",
  "version": "1.0.0",
  "description": "A comprehensive Markdown to PDF converter with support for Mermaid diagrams, math equations, syntax highlighting, and custom themes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "md2pdf": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "pdf",
    "converter",
    "mermaid",
    "katex",
    "syntax-highlighting",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "markdown-it": "^14.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdown-it-attrs": "^4.1.6",
    "puppeteer": "^21.6.1",
    "highlight.js": "^11.9.0",
    "mermaid": "^10.6.1",
    "katex": "^0.16.9",
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/markdown-it": "^13.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}